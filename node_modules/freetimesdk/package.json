{
    "name": "freetimesdk",
    "version": "1.0.2",
    "description": "The Official Payment SDK from Freetime Maker - A completely self-contained, open-source multi-cryptocurrency payment SDK for Node.js and browsers",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "prepare": "npm run build",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "dev": "ts-node src/index.ts",
        "prepublishOnly": "npm run build && npm test && npm run lint",
        "preversion": "npm run lint",
        "version": "npm run build",
        "postversion": "git push && git push --tags"
    },
    "keywords": [
        "cryptocurrency",
        "bitcoin",
        "ethereum",
        "payment",
        "sdk",
        "blockchain",
        "wallet",
        "transaction",
        "btc",
        "eth",
        "ltc",
        "bch",
        "doge",
        "sol",
        "matic",
        "bnb",
        "trx"
    ],
    "author": "Freetime Maker",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/FreetimeMaker/FreetimeSDK-NPM.git"
    },
    "bugs": {
        "url": "https://github.com/FreetimeMaker/FreetimeSDK-NPM/issues"
    },
    "homepage": "https://github.com/FreetimeMaker/FreetimeSDK-NPM#readme",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "dependencies": {
        "bech32": "^2.0.0",
        "bn.js": "^5.2.1",
        "bs58": "^6.0.0",
        "crypto-js": "^4.2.0",
        "elliptic": "^6.5.4",
        "ethers": "^6.8.0"
    },
    "devDependencies": {
        "@types/elliptic": "^6.4.18",
        "@types/jest": "^29.5.5",
        "@types/node": "^20.8.0",
        "@typescript-eslint/eslint-plugin": "^6.7.0",
        "@typescript-eslint/parser": "^6.7.0",
        "eslint": "^8.49.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.1",
        "typescript": "^5.2.2"
    },
    "engines": {
        "node": ">=16.0.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "browser": {
        "crypto": false
    }
}
